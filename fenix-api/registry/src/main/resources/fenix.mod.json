{
  "schema": 1,
  "id": "fenix-api-registry",
  "version": "${version}",
  "name": "Fenix API — Registry",
  "description": "Content registration: blocks, items, and the vanilla bookkeeping around them.",
  "authors": [
    "D4EMON"
  ],
  "license": "Apache-2.0",
  "contact": {
    "homepage": "https://github.com/D4EMONDEV/Fenix",
    "issues": "https://github.com/D4EMONDEV/Fenix/issues"
  },
  "side": "both",
  "depends": {
    "fenix": ">=0.1.0",
    "minecraft": "~${minecraft_version}"
  },
  "mixins": [
    "fenix-api-registry.mixins.json"
  ],
  "accessible": [
    "class net.minecraft.world.inventory.MenuType$MenuSupplier",
    "method net.minecraft.world.inventory.MenuType <init>",
    "class net.minecraft.client.gui.screens.MenuScreens$ScreenConstructor",
    "method net.minecraft.core.particles.SimpleParticleType <init>",
    "class net.minecraft.client.particle.ParticleResources$SpriteParticleRegistration",
    "method net.minecraft.client.particle.ParticleResources register"
  ]
}
